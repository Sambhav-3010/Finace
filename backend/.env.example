NODE_ENV=development
SERVICE_NAME=ly-node-api
PORT=5000
API_PREFIX=/api/v1
JSON_BODY_LIMIT=1mb
CORS_ORIGINS=http://localhost:3000

# Optional gateway auth
GATEWAY_API_KEY=

# Phase 1 default keeps the existing CLI bridge working.
# Switch to http after the FastAPI wrapper is running.
RAG_PROVIDER_MODE=cli
FASTAPI_BASE_URL=http://127.0.0.1:8000
FASTAPI_TIMEOUT_MS=45000
PYTHON_RAG_EXE=

BLOCKCHAIN_NETWORK=base-sepolia
BLOCKCHAIN_DEPLOYMENT_FILE=Blockchain/deployments/ComplianceAudit.base-sepolia.json
BLOCKCHAIN_STORE_SCRIPT=store-proof:base-sepolia
BLOCKCHAIN_WRITE_ENABLED=true
