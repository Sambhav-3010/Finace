# Blockchain Configuration Example
# Copy this file to .env and fill in your details.
# DO NOT commit your actual .env file.

# RPC URL for Base Sepolia (or your target network)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Your wallet private key (MUST have funds for gas)
PRIVATE_KEY=your_private_key_here
